{
  "name": "qa-case-study-makemycv",
  "version": "1.0.0",
  "description": "QA case study – MakeMyCV, tests E2E Playwright",
  "scripts": {
    "test":            "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:mobile":     "playwright test --grep @mobile",
    "test:all":        "playwright test",
    "test:headed":     "playwright test --headed --grep @smoke",
    "test:report":     "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "typescript":       "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
